# انسخ الملف ده لاسم .env.production واملأ القيم، لا ترفعه أبدًا لأي مكان عام
SECRET_KEY=غيّر-ده-لمفتاح-عشوائي-طويل-قبل-أي-استخدام-حقيقي
DEBUG=False

DB_NAME=biozone
DB_USER=biozone
DB_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=60

# سيبها False للاختبار المحلي (مفيش شهادة SSL حقيقية على localhost).
# لما تنشر على سيرفر حقيقي بدومين وشهادة فعلية، خليها True.
USE_HTTPS_SECURITY=False

# --- الدومين الحقيقي (لما يتحدد) ---
# سيبها فاضية دلوقتي (زي ما هي) — النظام هيفضل شغال بالإعدادات الافتراضية
# (localhost + *.trycloudflare.com). لما يبقى عندك دومين حقيقي، اكتبه هنا
# من غير ما تلمس أي كود، وبعدها docker compose restart web بس:
EXTRA_ALLOWED_HOSTS=
EXTRA_CSRF_TRUSTED_ORIGINS=

# --- Gunicorn ---
# سيبها فاضية عشان يتحسب تلقائيًا من عدد أنوية السيرفر الفعلي (2×الأنوية + 1).
# حطها بس لو عايز رقم يدوي ثابت بدل الحساب التلقائي:
GUNICORN_WORKERS=

# --- Sentry (اختياري تمامًا) ---
# سيبها فاضية عشان يفضل الاعتماد على الـ logging المحلي بس (logs/errors.log).
# لو حابب Sentry، سجّل حساب مجاني على sentry.io واحط الـ DSN بتاعك هنا:
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=1.0
